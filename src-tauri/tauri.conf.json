{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ibra OS",
  "version": "0.1.0",
  "identifier": "com.ibraos.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "Ibra OS",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "decorations": true,
        "transparent": false,
        "center": true,
        "titleBarStyle": "Transparent"
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "icons/32x32.png",
      "iconAsTemplate": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "shortDescription": "Personal Creative Operating System",
    "longDescription": "Ibra OS is a private creative command centre for projects, opportunities, design language memory, moodboards, finance, learning, and AI agents.",
    "copyright": "© 2025 Ibra Balogun",
    "macOS": {
      "minimumSystemVersion": "10.15",
      "frameworks": []
    },
    "windows": {
      "digestAlgorithm": "sha256",
      "certificateThumbprint": null,
      "timestampUrl": ""
    }
  }
}
